# リポジトリルートに `.env` としてコピーして使う（`.env` は Git 管理しません）。
# Docker Compose の frontend サービスが参照します。
#
# 開発用のデフォルト（ホストから API にアクセスする URL と、Compose 内から backend へ繋ぐ URL）

NEXT_PUBLIC_API_BASE_URL=http://localhost:8001
API_INTERNAL_BASE_URL=http://backend:8000
# バックエンド CORS 許可オリジン（カンマ区切り。Docker Compose の backend サービスが参照）
CORS_ORIGINS=http://localhost:3001

# --- SMTP（Mailgun の SMTP 認証。/api/admin/mail/send で使用）---
# Mailgun ダッシュボードの Sending > Domain settings > SMTP credentials 等を参照
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@mg.example.com
SMTP_PASSWORD=your_smtp_password
# 465 + SSL の場合は SMTP_USE_SSL=true / SMTP_USE_TLS=false に
SMTP_USE_TLS=true
SMTP_USE_SSL=false
# From（未設定時は SMTP_USER）
MAIL_FROM=noreply@mg.example.com
SMTP_TIMEOUT=30

# テナント管理者／ユーザー追加時の招待メールに記載する管理画面ログイン URL（フル URL）
# 例: https://example.com/admin/login または http://localhost:3001/admin/login
# ADMIN_LOGIN_URL=

# パスワード再設定メール内のリンク用オリジン（末尾スラッシュなし）。未設定なら ADMIN_LOGIN_URL または CORS_ORIGINS 先頭から推測。
# 例: http://localhost:3001 または https://example.com
# PASSWORD_RESET_PUBLIC_BASE_URL=

# お問い合わせフォーム: シスアド宛通知メールの送信先フォールバック（任意）
# DB に role=sysadmin のユーザがいる場合はそのメールが優先されます。無いときのみカンマ区切りで複数指定できます。
# INQUIRY_NOTIFY_EMAIL=admin@example.com

# --- OpenAI（マルチエージェント API `/api/admin/agents/run` で使用）---
# OPENAI_API_KEY=sk-...
# 任意。未設定時は SDK 既定（例: gpt-4.1）。Agents SDK が参照します。
# OPENAI_DEFAULT_MODEL=gpt-4.1
