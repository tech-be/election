# リポジトリルートに `.env` としてコピーして使う（`.env` は Git 管理しません）。
# Docker Compose の frontend サービスが参照します。
#
# 開発用のデフォルト（ホストから API にアクセスする URL と、Compose 内から backend へ繋ぐ URL）

NEXT_PUBLIC_API_BASE_URL=http://localhost:8001
API_INTERNAL_BASE_URL=http://backend:8000
# バックエンド CORS 許可オリジン（カンマ区切り。Docker Compose の backend サービスが参照）
CORS_ORIGINS=http://localhost:3001

# --- SMTP（Mailgun の SMTP 認証。/api/admin/mail/send で使用）---
# Mailgun ダッシュボードの Sending > Domain settings > SMTP credentials 等を参照
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@mg.example.com
SMTP_PASSWORD=your_smtp_password
# 465 + SSL の場合は SMTP_USE_SSL=true / SMTP_USE_TLS=false に
SMTP_USE_TLS=true
SMTP_USE_SSL=false
# From（未設定時は SMTP_USER）
MAIL_FROM=noreply@mg.example.com
SMTP_TIMEOUT=30
